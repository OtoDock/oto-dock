{
  "name": "ssh-hosts",
  "label": "SSH",
  "description": "SSH access to admin-configured hosts, straight from the agent's shell",
  "version": "1.1.0",
  "category": "custom",
  "server": {
    "runtime": "python",
    "transport": "stdio",
    "command": "venv/bin/python",
    "args": [
      "server.py"
    ]
  },
  "credentials": {
    "type": "none"
  },
  "instances": {
    "delivery": "none",
    "fields": [
      {
        "key": "name",
        "label": "Host Name",
        "input_type": "text",
        "required": true
      },
      {
        "key": "host",
        "label": "Host / IP",
        "input_type": "text",
        "required": true
      },
      {
        "key": "port",
        "label": "Port",
        "input_type": "number",
        "default": "22"
      },
      {
        "key": "username",
        "label": "Username",
        "input_type": "text",
        "required": true
      },
      {
        "key": "key_name",
        "label": "SSH Key",
        "input_type": "ssh_key_select"
      }
    ],
    "max_instances": 0
  },
  "config": [],
  "env": {},
  "agent_env": {},
  "data_dirs": {
    "keys": "keys/"
  },
  "assignment_mode": "explicit",
  "exclude_from": [],
  "skills": [],
  "permissions": {
    "default_tier": "standard",
    "rules": [
      {
        "tool": "list_ssh_hosts",
        "tier": "open"
      }
    ]
  },
  "patched": false,
  "patch_note": null,
  "network_targets": [
    {
      "source": "instance",
      "host_key": "host",
      "port_key": "port",
      "port_default": 22
    }
  ],
  "remote_policy": "admin_paired_only"
}
