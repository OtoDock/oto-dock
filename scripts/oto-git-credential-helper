#!/bin/bash
# OtoDock git credential helper тАФ bridges `git push`/`git fetch` to the
# `GH_TOKEN` env var injected by the github-mcp manifest's
# `credentials.oauth.env_injection`.
#
# Wired in via `/etc/gitconfig`:
#
#     [credential "https://github.com"]
#         helper = /usr/local/bin/oto-git-credential-helper
#
# The URL-namespaced `credential "https://github.com"` form means this
# helper ONLY fires for github.com URLs тАФ never touches other hosts.
# Installed by `scripts/install-baseline-tools.sh`.
#
# Protocol (git credential helper API):
#   - Operation passed as $1: "get" | "store" | "erase"
#   - For "get": git writes URL components to stdin (one key=value per
#     line, blank line terminator); we write back username + password,
#     blank line terminator. We ignore stdin since we only authenticate
#     github.com.
#   - For "store" / "erase": no-op (we don't persist anything; the
#     proxy is the source of truth for the token).

set -u

if [ "${1:-}" = "get" ]; then
    # Empty GH_TOKEN тЖТ output empty password, git falls back to its
    # next credential helper (or interactive prompt). Don't error.
    printf 'username=x-access-token\npassword=%s\n' "${GH_TOKEN:-}"
fi

# store / erase / unknown ops тЖТ no-op, exit 0
exit 0
